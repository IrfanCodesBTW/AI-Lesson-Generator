# ─── Runtime DB (Supabase Transaction pooler, port 6543) ───────────────
DATABASE_URL=postgresql://postgres.PROJECTREF:PASSWORD@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1

# ─── Migrations DB (Supabase Direct, port 5432) ────────────────────────
DATABASE_DIRECT_URL=postgresql://postgres:PASSWORD@db.PROJECTREF.supabase.co:5432/postgres

# ─── Supabase (server-only) ────────────────────────────────────────────
SUPABASE_URL=https://PROJECTREF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-32-or-more-random-characters-here
JWT_EXPIRES_IN=24h

# ─── Server ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ─── Gemini (lesson generator primary path) ────────────────────────────
# Leave GEMINI_API_KEY empty to use the rule-based template fallback
# (always succeeds, no external dependency).
# Get a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_TIMEOUT_MS=8000

# ─── Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
